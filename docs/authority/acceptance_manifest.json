  "coverage_rules": {
    "accepted_execution_modes": [
      "async_no_graph",
      "graph_fixed"
    ],
    "kernel_family_modes": {
      "baseline_gpu": "Phase 5/6 device-resident path without Phase 7 custom hotspot kernels",
      "custom_gpu": "Phase 7 hotspot kernels enabled"
    },
    "case_family_rules": {
      "R2": {
        "phase_gate_family": true,
        "required_phase5_slices": [
          "generic boundedness + interface-transport",
          "static-droplet + surface-tension"
        ]
      },
      "R1-core": {
        "default_reduced_case_for_backend_parity": true,
        "default_reduced_case_for_execution_mode_parity": true,
        "default_reduced_case_for_generic_vs_custom_kernel_comparison": true
      },
      "R1": {
        "role": "reduced nozzle acceptance case for routine architecture and profiling baselines"
      },
      "R0": {
        "role": "production-shape acceptance case"
      }
    },
    "nozzle_kernel_promotion_policy": "The required milestone-1 nozzle signoff path is baseline_gpu on R1 and R0. Matching custom_gpu nozzle rows are optional benchmark rows admitted only when the implementation branch intentionally enables Phase 7 custom kernels.",
    "backend_restrictions": {
      "amgx_admitted_case_ids": [
        "R1-core"
      ],
      "amgx_admitted_execution_modes": [
        "async_no_graph"
      ],
      "amgx_production_eligible": false,
      "amgx_required_pressure_bridge_mode": "DeviceDirect",
      "amgx_without_required_bridge_classification": "diagnostic_only_not_an_accepted_tuple"
    },
    "optional_benchmark_policy": "Rows marked optional_benchmark_only do not block milestone-1 signoff when absent. If present, they must satisfy their tolerance and parity classes.",
    "pinned_host_policy": "PinnedHost pressure staging is never production-eligible, always classifies a run as bring-up/correctness-only, and never satisfies an accepted AmgX tuple's DeviceDirect admission prerequisite.",
    "write_timestep_policy": "Write timesteps are excluded from timed steady-state windows unless a named write-cadence variant is explicitly added later.",
    "tuple_lookup_rule": "Automation must use tuple_id directly and may not infer a row from only case/backend/execution mode."
  },
  "nvtx_contract_defaults": {
    "required_orchestration_ranges": [
      "solver/timeStep",
      "solver/steady_state",
      "solver/pimpleOuter"
    ],
    "optional_stage_ids_when_enabled": [
      {
        "stage_id": "write_stage",
        "condition": "Only future manifest rows that explicitly admit a write-cadence timed window may require or permit write_stage inside the acceptance window."
      }
    ],
    "mandatory_range_gate_rule": "mandatory_nvtx_ranges_present is true only when every required orchestration range and every tuple-specific required_stage_id is present."
  },
  "hard_gates": {
    "unexpected_htod_bytes": {
      "operator": "==",
      "value": 0
    },
    "unexpected_dtoh_bytes": {
      "operator": "==",
      "value": 0
    },
    "cpu_um_faults": {
      "operator": "==",
      "value": 0
    },
    "gpu_um_faults": {
      "operator": "==",
      "value": 0
    },
    "cudaDeviceSynchronize_calls": {
      "operator": "==",
      "value": 0,
      "scope": "steady_state_inner_ranges"
    },
    "post_warmup_alloc_calls": {
      "operator": "==",
      "value": 0
    },
    "mandatory_nvtx_ranges_present": {
      "operator": "==",
      "value": true
    },
    "cpu_boundary_fallback_events": {
      "operator": "==",
      "value": 0
    },
    "host_patch_execution_events": {
      "operator": "==",
      "value": 0
    },
    "pinned_host_pressure_stage_events": {
      "operator": "==",
      "value": 0,
      "scope": "production_acceptance_runs"
    },
    "host_setFields_startup_events": {
      "operator": "==",
      "value": 0,
      "scope": "accepted_startup_path"
    },
    "unsafe_functionObject_commit_events": {
      "operator": "==",
      "value": 0,
      "scope": "timed_steady_state_windows"
    }
  },
  "soft_gates": {
    "graph_launches_per_step": {
      "operator": "<=",
      "value": 4
    },
    "top_kernel_time_regression_pct": {
      "operator": "<=",
      "value": 10.0,
      "units": "percent",
      "baseline": "locked_baseline"
    }
  },
  "disposition_rules": {
    "hard_gate_failure": {
      "formal_acceptance_result": "fail",
      "release_eligible": false,
      "baseline_lock_eligible": false
    },
    "soft_gate_failure": {
      "formal_acceptance_result": "soft_fail",
      "diagnostic_archive_allowed": true,
      "release_eligible_without_waiver": false,
      "baseline_lock_eligible_without_waiver": false,
      "required_waiver_fields": [
        "manifest_revision",
        "tuple_id"
      ]
    },
    "diagnostic_or_bringup_run_outside_accepted_tuple_matrix": {
      "may_report_soft_gates": true,
      "formal_acceptance_verdict_emitted": false
    }
  },
  "threshold_classes": {
    "field_qoi": {
      "TC_R2_TRANSPORT": {
        "alpha_phase_sum_abs_max": 1e-12,
        "alpha1_min": -1e-10,
        "alpha1_max": 1.0000000001,
        "integral_mass_imbalance_pct_point_delta_vs_cpu_baseline_max": 0.1,
        "allow_solver_divergence": false,
        "accepted_window": "transport"
      },
      "TC_R2_SURFACE": {
        "alpha_phase_sum_abs_max": 1e-12,
        "alpha1_min": -1e-10,
        "alpha1_max": 1.0000000001,
        "static_droplet_laplace_pressure_jump_relative_error_max_pct": 1.0,
        "spurious_current_peak_delta_vs_cpu_baseline_max_pct": 20.0
      },
      "TC_R1CORE_GENERIC": {
        "integral_mass_imbalance_pct_point_delta_vs_cpu_baseline_max": 0.1,
        "pressure_drop_relative_error_max_pct": 0.5,
        "mass_flow_relative_error_max_pct": 0.5,
        "discharge_coefficient_proxy_relative_error_max_pct": 1.0,
        "matched_transient_window_required": true
      },
      "TC_R1_NOZZLE": {
        "mass_flow_relative_error_max_pct": 0.5,
        "pressure_drop_relative_error_max_pct": 0.5,
        "max_alpha_overshoot_undershoot_abs": 1e-8,
        "allow_solver_divergence_attributable_to_nozzle_path": false,
        "nozzle_path_divergence_observation_window_timesteps": 100
      },
      "TC_R0_NOZZLE": {
        "discharge_coefficient_relative_error_max_pct": 1.0,
        "spray_half_angle_difference_max_degrees": 2.0,
        "air_core_onset_time_difference_max_pct_of_reference_startup_window": 5.0
      }
    },
    "parity_replay": {
      "RP_STRICT": {
